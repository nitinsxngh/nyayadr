# Frontend (Vite) — optional legacy; prefer server keys below
VITE_GEMINI_API_KEY=your_gemini_api_key

# Server AI — Gemini first, OpenAI fallback (server only, never expose to frontend)
GEMINI_API_KEY=your_gemini_api_key
OPENAI_API_KEY=your_openai_api_key
OPENAI_REPORT_MODEL=gpt-4o-mini

# Portal access — share this key with authorized users only
PORTAL_ACCESS_KEY=change-this-to-a-strong-shared-key

# Auth token signing (use a long random string in production)
JWT_SECRET=change-this-jwt-secret-in-production

# MongoDB — use Atlas connection string or local:
# MONGODB_URI=mongodb://127.0.0.1:27017/nyayadr
MONGODB_URI=mongodb+srv://USER:PASSWORD@cluster.mongodb.net/nyayadr?retryWrites=true&w=majority

# API server port (use platform PORT on live hosting)
PORT=3001

# Production: run `npm run build` then `npm start` (serves API + UI on one port)
# If frontend and API are on different domains, set at build time:
# VITE_API_URL=https://your-api-domain.com/api

# AWS S3 — party audio recordings (server only, never expose to frontend)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=ap-south-1
# Bucket must exist in AWS_REGION; name must be lowercase (e.g. nyay-adr not nyayADR)
AWS_S3_BUCKET=nyay-adr
AWS_S3_PREFIX=audios
